PORT=8080

# Postgres: Supabase Dashboard → Project Settings → Database
# - Use "Connection string" → URI. If you forgot the DB password: same page → "Reset database password"
#   (Supabase will show the new password once; put it in this URL as the password segment).
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# --- If you see: dial tcp [IPv6...]:5432: connect: network is unreachable ---
# The direct host db.<ref>.supabase.co often has ONLY IPv6 in public DNS (no A record). In that case
# no client-side "prefer IPv4" can work: there is no IPv4 address to connect to. Fix ONE of these:
#
# (A) REQUIRED for many IPv4-only networks: use "Connection pooling" → Transaction mode (port 6543).
#     Copy that URI from the same Database settings page. Host is usually *.pooler.supabase.com (IPv4).
#
# (B) Or enable working IPv6 routing to the internet on your machine/network.
#
# (C) DATABASE_PREFER_IPV4=false — use pgx default DNS order (only matters when both A and AAAA exist).
#
# Note: `dig +short A db.PROJECT_REF.supabase.co` may print nothing; that means no IPv4 in DNS for that name.

# JWT: Supabase Dashboard → Project Settings → API → JWT Secret (long string; "Reveal" / copy).
# Required for authenticated routes (login, write review). Public GET /api/businesses works without it in dev.
SUPABASE_JWT_SECRET=

# Optional: issuer check (e.g. https://PROJECT_REF.supabase.co/auth/v1)
# SUPABASE_JWT_ISSUER=

# Comma-separated; no trailing slash on each origin (https://app.vercel.app not ...app/)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_PER_MINUTE=120
