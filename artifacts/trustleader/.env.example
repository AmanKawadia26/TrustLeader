# Supabase (public anon key — safe for Vite bundle)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: production origin for email confirmation links (defaults to current browser URL in dev).
# In Supabase Dashboard → Authentication → URL Configuration, set Site URL and add this origin
# to Redirect URLs (e.g. http://localhost:5173/** for local Vite — not 3000 unless your app runs there).
# VITE_AUTH_REDIRECT_URL=https://your-production-domain.com

# API: leave unset in dev to use same origin + Vite proxy to Go (see vite.config.ts)
# VITE_API_URL=http://localhost:5173

# Optional: override proxy target (default http://127.0.0.1:8080)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8080
