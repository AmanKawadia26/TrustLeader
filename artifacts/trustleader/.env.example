# Supabase (public anon key — safe for Vite bundle)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: force origin for Supabase email confirmation (overrides Vercel auto URL + defaults).
# On Vercel, vite.config injects https://$VERCEL_URL at build time; set this only for a custom domain.
# Supabase → Authentication → URL Configuration: Site URL = your Vercel URL; Redirect URLs must include it.
# VITE_AUTH_REDIRECT_URL=https://trust-leader-trustleader.vercel.app

# API: leave unset in dev to use same origin + Vite proxy to Go (see vite.config.ts)
# VITE_API_URL=http://localhost:5173

# Optional: override proxy target (default http://127.0.0.1:8080)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8080
